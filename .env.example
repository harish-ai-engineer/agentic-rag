# Copy to .env and fill in. Values must NOT be wrapped in quotes.

# OpenAI (required)
OPENAI_API_KEY=sk-...

# AgentGuard observability (Langfuse-compatible API keys)
AGENTGUARD_PUBLIC_KEY=pk-lf-...
AGENTGUARD_SECRET_KEY=sk-lf-...
AGENTGUARD_HOST=https://agentgaurd-a0acc6egbhced0dc.centralindia-01.azurewebsites.net

# Local R2R API
R2R_BASE_URL=http://localhost:7272

# Local ChromaDB store used by the MCP retrieval server
CHROMA_DB_DIR=./chroma_db
CHROMA_COLLECTION=agentic_rag_docs
CHROMA_AUTO_SYNC=true
EMBEDDING_MODEL=text-embedding-3-small
RAG_MODEL=gpt-4o-mini

# Model used by all three agents
AGENT_MODEL=gpt-4o-mini
